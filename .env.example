# ── Server ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Retell AI ───────────────────────────────────
RETELL_API_KEY=your_retell_api_key_here

# ── n8n Integration ─────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/retell

# ── Webhook Security ────────────────────────────
WEBHOOK_AUTH_TOKEN=your_secure_webhook_token_here

# ── Twilio (SMS Verification Loop) ──────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+49xxxxxxxxxx

# ── Logging ─────────────────────────────────────
LOG_LEVEL=info
