# 1) Domain anpassen (überall gleicher Name wie N8N_HOST in .env)
# 2) Nach /etc/nginx/sites-available/n8n.stress-test.net kopieren, symlink nach sites-enabled, nginx -t, reload
# 3) SSL: sudo certbot --nginx -d n8n.stress-test.net

server {
	listen 80;
	listen [::]:80;
	server_name n8n.stress-test.net;

	location / {
		proxy_pass http://127.0.0.1:5678;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		proxy_read_timeout 86400;
		proxy_send_timeout 86400;
	}
}
